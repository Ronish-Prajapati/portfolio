// Prisma schema for the Ronish Prajapati portfolio.
// Database: PostgreSQL (Neon free tier).
// Images are stored as Cloudinary URL strings — never as binary in the DB.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Singleton site profile — drives Hero, About and Footer.
model Profile {
  id               String   @id @default(cuid())
  name             String
  title            String
  shortDescription String
  about            String   @db.Text
  // Optional secondary bio paragraphs rendered in the About section.
  aboutParagraphs  String[] @default([])
  techStack        String[] @default([])
  profileImage     String?
  resumeUrl        String?
  githubUrl        String?
  linkedinUrl      String?
  email            String
  phone            String?
  // Hero-specific copy (kept separate so Hero text is editable).
  heroGreeting     String?
  heroHeadline     String?
  heroHighlight    String?
  heroSubtitle     String?
  heroImage        String?
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())
}

model Project {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  description     String
  longDescription String   @db.Text
  image           String?
  githubLink      String?
  liveLink        String?
  technologies    String[] @default([])
  features        String[] @default([])
  year            String?
  featured        Boolean  @default(false)
  order           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([featured])
}

model Skill {
  id          String   @id @default(cuid())
  name        String
  category    String
  // Either a lucide-react icon name (e.g. "Code2") or a Cloudinary URL.
  icon        String?
  description String?
  proficiency Int      @default(80)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}

model Experience {
  id           String    @id @default(cuid())
  company      String
  position     String
  location     String?
  // Human-readable period label, e.g. "July 2024 - Present".
  period       String?
  description  String    @db.Text
  highlights   String[]  @default([])
  technologies String[]  @default([])
  startDate    DateTime?
  endDate      DateTime?
  current      Boolean   @default(false)
  order        Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Education {
  id          String   @id @default(cuid())
  institution String
  degree      String
  description String?  @db.Text
  startYear   String
  endYear     String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Blog {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  excerpt   String?
  content   String   @db.Text
  thumbnail String?
  images    String[] @default([])
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published])
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String
  message   String   @db.Text
  image     String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GalleryImage {
  id        String   @id @default(cuid())
  title     String?
  image     String
  caption   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([read])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
