# ===========================================================================
# DATABASE (Neon Postgres — https://neon.tech)
# ===========================================================================
# Pooled connection string used by the app at runtime (PgBouncer).
# Copy the "Pooled connection" string from the Neon dashboard.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# Direct (non-pooled) connection string used by Prisma Migrate.
# Copy the "Direct connection" string from the Neon dashboard.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"

# ===========================================================================
# AUTH (NextAuth v5 / Auth.js)
# ===========================================================================
# Generate with:  openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"
# In production set this to your deployed URL, e.g. https://ronish-prajapati.com.np
NEXTAUTH_URL="http://localhost:3000"

# Seed admin account (used by `prisma db seed` to create the first admin).
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-strong-password"
ADMIN_NAME="Ronish Prajapati"

# ===========================================================================
# CLOUDINARY (image/file uploads — https://cloudinary.com)
# ===========================================================================
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
# Public cloud name is also exposed to the client for building image URLs.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"

# ===========================================================================
# SITE / SEO
# ===========================================================================
# Canonical site URL — used for metadata, sitemap, robots, OpenGraph.
# IMPORTANT: in production set this to your real domain (no trailing slash),
# e.g. https://ronish-prajapati.com.np — otherwise sitemap/canonical URLs break.
NEXT_PUBLIC_SITE_URL="https://ronish-prajapati.com.np"

# Google Search Console verification token (the content of the
# <meta name="google-site-verification"> tag). Optional but recommended.
GOOGLE_SITE_VERIFICATION=""

# Optional: where contact-form notifications should be summarised (not required).
CONTACT_NOTIFY_EMAIL="ronishprajapati0@gmail.com"
